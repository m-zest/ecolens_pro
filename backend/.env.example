# Local development env for the FastAPI backend.
# Copy to `backend/.env` and fill in. Never commit the real .env.

# ─── MongoDB ──────────────────────────────────────────────────────────
# Local docker: mongodb://localhost:27017
# Atlas SRV:    mongodb+srv://<user>:<pw>@cluster.xxxxx.mongodb.net/ecolens?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017
DB_NAME=ecolens

# ─── AI provider selection ────────────────────────────────────────────
# Which provider serves the /packagings/{id}/story endpoint.
# anthropic | fireworks | minimax | auto
# "auto" uses whichever key is set, preference order: anthropic > fireworks > minimax.
AI_PROVIDER=auto

# ─── Anthropic (Claude Sonnet 4.5 — best prose) ───────────────────────
# Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=claude-sonnet-4-5-20250929

# ─── Fireworks AI (Llama 3.3 70B or similar — cheap & fast) ───────────
# Get one at https://fireworks.ai → Account → API keys.
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxx
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# ─── MiniMax (strong multilingual: IT / DE / PL) ──────────────────────
# Get one at https://www.minimaxi.com → API Keys.
MINIMAX_API_KEY=mm_xxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1/chat/completions

# ─── CORS + public URL (used to build QR / OG links) ──────────────────
CORS_ORIGINS=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
